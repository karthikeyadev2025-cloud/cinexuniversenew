# ════════════════════════════════════════════════════════
# Cinex Universe — Environment Variables
# Copy this file to .env and fill in your values.
# All variables marked REQUIRED must be set for the app to work.
# ════════════════════════════════════════════════════════

# ─── REQUIRED: Database ─────────────────────────────────
# PostgreSQL connection string (Supabase, Neon, Railway, etc.)
DATABASE_URL=postgresql://postgres:[password]@db.[project].supabase.co:5432/postgres

# ─── REQUIRED: JWT Secret ───────────────────────────────
# Any long random string — used to sign/verify auth tokens.
# Generate one with: openssl rand -base64 64
APP_SECRET=change-me-to-a-long-random-secret

# ─── REQUIRED: Public App URL ───────────────────────────
# Full URL where the app is deployed (no trailing slash).
# Used for OAuth redirect URIs — must match exactly what you
# register in Google Cloud Console.
# Local:      http://localhost:3000
# Production: https://your-project.vercel.app   (or custom domain)
APP_URL=http://localhost:3000

# ─── OPTIONAL: Google OAuth ─────────────────────────────
# Create credentials at https://console.cloud.google.com/
# Authorised redirect URI must be: {APP_URL}/api/oauth/google/callback
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# ─── OPTIONAL: Razorpay Payments ────────────────────────
# Get keys from https://dashboard.razorpay.com/app/keys
RAZORPAY_KEY_ID=
RAZORPAY_KEY_SECRET=

# ─── OPTIONAL: Replicate AI ─────────────────────────────
# Get token from https://replicate.com/account/api-tokens
REPLICATE_API_TOKEN=

# ─── AUTO-GENERATED (do not modify manually) ────────────
APP_ID=
VITE_APP_ID=
VITE_KIMI_AUTH_URL=https://auth.kimi.com
KIMI_AUTH_URL=https://auth.kimi.com
KIMI_OPEN_URL=https://open.kimi.com
OWNER_UNION_ID=
